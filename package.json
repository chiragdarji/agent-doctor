{
  "name": "@chiragdarji/agent-doctor",
  "version": "0.2.2",
  "description": "Semantic health check for AI agent instruction files",
  "keywords": [
    "claude",
    "agents",
    "CLAUDE.md",
    "AGENTS.md",
    "cursor",
    "mcp",
    "linter",
    "ai",
    "llm"
  ],
  "author": "Chirag Darji",
  "license": "MIT",
  "homepage": "https://github.com/chiragdarji/agent-doctor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiragdarji/agent-doctor.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-doctor": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src tests",
    "typecheck": "tsc --noEmit",
    "postbuild": "chmod +x dist/cli.js",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test:run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.33.0",
    "tiktoken": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
